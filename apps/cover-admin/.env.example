PORT=3000

# MySQL 8 (用户信息、refresh_token)
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=cover_admin

# Redis (access_token)
# 若 redis.conf 配置了 requirepass，则 REDIS_PASSWORD 必须与之一致，否则会出现 NOAUTH。
# 本地 Redis 未设密码时：删除本行或留空 REDIS_PASSWORD=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=nest_redis_pwd
# Redis 6+ ACL 非 default 用户时填写（一般可省略）
# REDIS_USERNAME=default

# 切换生效角色（/api/auth/switch-role）在 Redis 中的过期时间（秒），默认 30 天
# REDIS_ACTIVE_ROLE_TTL_SECONDS=2592000

# JWT
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_ACCESS_EXPIRES=60m
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES=7d
