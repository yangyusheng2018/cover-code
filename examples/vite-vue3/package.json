{
  "name": "vite-vue3-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter istanbul-live-vite-plugin run build",
    "prebuild": "pnpm --filter istanbul-live-vite-plugin run build",
    "dev": "vite",
    "build": "vite build",
    "build:staging": "vite build --mode staging",
    "preview": "vite build --mode staging && vite preview --mode staging"
  },
  "dependencies": {
    "istanbul-live-vite-plugin": "workspace:*",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "vite": "^6.2.6"
  }
}
